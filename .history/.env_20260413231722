# CodeRunner Academy - Environment Configuration
# For Moodle + CodeRunner with Security Features

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_TYPE=mysqli
DB_HOST=localhost
DB_NAME=moodle
DB_USER=root
DB_PASSWORD=

# ============================================
# MOODLE CORE SETTINGS
# ============================================
MOODLE_URL=http://localhost
MOODLE_ADMIN_USERNAME=admin
MOODLE_ADMIN_PASSWORD=admin123
MOODLE_SITE_NAME=CodeRunner Academy

# ============================================
# PHP CONFIGURATION
# ============================================
PHP_VERSION=8.2
SERVER_PORT=80

# ============================================
# CODERUNNER SECURITY SETTINGS
# ============================================
CODERUNNER_SECURITY_ENABLED=true
CODERUNNER_MAX_CODE_SIZE=100000
CODERUNNER_MAX_OUTPUT_SIZE=50000
CODERUNNER_EXECUTION_TIMEOUT=5
CODERUNNER_MAX_SUBMISSIONS_PER_MINUTE=10
CODERUNNER_MAX_REQUESTS_PER_IP=50

# ============================================
# AUDIT & LOGGING
# ============================================
AUDIT_LOG_PATH=/moodledata/logs/audit
SECURITY_LOG_PATH=/moodledata/logs/security
DEBUG_MODE=false

# ============================================
# RENDER DEPLOYMENT (Use these for Render.com)
# ============================================
# When deploying to Render, use:
# RENDER_DB_HOST=postgres.render.com (or MySQL equivalent)
# RENDER_DB_PORT=5432
# RENDER_DATABASE_URL=postgresql://user:pass@host:port/dbname
