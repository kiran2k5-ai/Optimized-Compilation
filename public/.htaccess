# Moodle .htaccess - Handle CSS, JavaScript, and other assets

<IfModule mod_rewrite.c>
    RewriteEngine on
    
    # Ensure SCRIPT_FILENAME is set correctly
    RewriteBase /public/
    
    # Don't rewrite real files or directories
    RewriteCond %{REQUEST_FILENAME} -d [OR]
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -l
    RewriteRule ^.*$ - [NC,L]
    
    # Handle CSS files from theme/styles.php
    RewriteRule ^theme/styles\.php/(.+)$ theme/styles.php?$1 [QSA,L]
    RewriteRule ^theme/styles_debug\.php/(.+)$ theme/styles_debug.php?$1 [QSA,L]
    
    # Handle JavaScript files  
    RewriteRule ^theme/javascript\.php/(.+)$ theme/javascript.php?$1 [QSA,L]
    
    # Handle image files
    RewriteRule ^theme/image\.php/(.+)$ theme/image.php?$1 [QSA,L]
    
    # Handle font files
    RewriteRule ^theme/font\.php/(.+)$ theme/font.php?$1 [QSA,L]
    
    # Handle file serving
    RewriteRule ^file\.php/(.*) file.php?file=/$1 [QSA,L]
    RewriteRule ^pluginfile\.php/(.*) pluginfile.php?file=/$1 [QSA,L]
    RewriteRule ^draftfile\.php/(.*) draftfile.php?file=/$1 [QSA,L]
    
    # Default to index.php for other requests
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

<IfModule mod_headers.c>
    # Set proper cache headers for static assets
    <FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
    
    # Don't cache HTML or PHP
    <FilesMatch "\.(html|htm|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    
    # Fix for CORS and font loading
    <FilesMatch "\.(woff|woff2|ttf|eot)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
    # Compress text, HTML, JavaScript, CSS, and XML
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/x-font
    AddOutputFilterByType DEFLATE application/x-font-truetype
    AddOutputFilterByType DEFLATE application/x-font-opentype
    AddOutputFilterByType DEFLATE application/vnd.ms-fontobject
    AddOutputFilterByType DEFLATE font/truetype
    AddOutputFilterByType DEFLATE font/opentype
</IfModule>

# Disable directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "(^#.*#|\.(ini|php~|php.~))$">
    Deny from all
</FilesMatch>

# Protect hidden files and directories
<FilesMatch "^\.|^\.\.">
    Deny from all
</FilesMatch>
